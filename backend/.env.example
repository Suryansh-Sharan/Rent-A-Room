# =============================================================================
# Rent-A-Room Backend Environment Variables
# =============================================================================
# Copy this file to `.env` in the same directory (backend/) and fill in values:
#   cp .env.example .env
#
# This file is tracked in git. Never commit your actual `.env` with real secrets.
# =============================================================================

# --- Database (PostgreSQL / Supabase) ---
# Use your Supabase connection string or any PostgreSQL URL.
# The app auto-converts postgresql:// to postgresql+asyncpg:// if needed.
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# --- JWT Authentication ---
# Generate a strong random secret, e.g.: openssl rand -hex 32
JWT_SECRET_KEY=your_random_32_byte_hex_string_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Cloudinary (room image uploads) ---
# Create a free account at https://cloudinary.com
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# --- Pinecone (vector search for AI room matching) ---
# Create an index at https://www.pinecone.io
# PINECONE_HOST is the index host URL from the Pinecone dashboard.
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_HOST=your-index-host.pinecone.io

# --- Ollama (local LLM for AI compatibility scoring) ---
# Run `ollama serve` locally, then pull the model listed below.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:4b

# --- Resend Email (optional — emails are skipped if not configured) ---
# Sign up at https://resend.com to send request/status notification emails.
RESEND_API_KEY=
EMAIL_FROM=Rent-A-Room <onboarding@resend.dev>
